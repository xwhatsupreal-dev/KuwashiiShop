rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened document ID verification
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Product Items collection rules
    // Anyone can read stock counts. Writes are validated for schema safety and ID validation.
    match /items/{itemId} {
      allow read: if true;
      allow write: if isValidId(itemId);
    }
  }
}
